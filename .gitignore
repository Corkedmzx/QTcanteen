CMakeCache.txt
CMakeFiles/
CMakeScripts/
cmake_install.cmake
install_manifest.txt
compile_commands.json
CTestTestfile.cmake
_deps/
*.cmake
!CMakeLists.txt

# Qt Creator 配置
.qtcreator/
*.pro.user
*.pro.user.*

# 构建目录
build/
out/
bin/
lib/
*.exe
*.dll
*.so
*.dylib
*.a
*.lib

