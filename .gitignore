user.json
user.json.bak
dishes.json
dishes.json.bak
orders.json
orders.json.bak

# 人脸识别模型文件（运行时生成）
face_model.xml
face_model_deep.json
face_model_mapping.json
faces/
*.jpg
*.jpeg
*.png
# images 目录只保留空文件夹，不包含图片文件
images/*
!images/.gitkeep

# ============================================
# 第三方库文件（如果包含在项目中）
# ============================================
# SeetaFace DLL 文件（运行时需要，但不应该提交）
libSeeta*.dll
libtennis.dll

# OpenCV Haar Cascade 文件（如果从OpenCV复制到项目）
haarcascade_*.xml

# DNN 模型文件（如果下载到项目中，可选）
# 如果模型文件很大，建议排除；如果作为示例，可以保留
# models/*.t7
# models/*.pb
# models/*.onnx

